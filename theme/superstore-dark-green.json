{
  "name": "Superstore Dark Green",
  "dataColors": [
    "#22C55E",
    "#2DD4BF",
    "#A3E635",
    "#38BDF8",
    "#FBBF24",
    "#4ADE80",
    "#14B8A6",
    "#84CC16"
  ],
  "background": "#0A1410",
  "foreground": "#E8F5ED",
  "tableAccent": "#22C55E",
  "good": "#22C55E",
  "neutral": "#FBBF24",
  "bad": "#F87171",
  "maximum": "#6EE7A8",
  "center": "#16A34A",
  "minimum": "#0F3D26",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#10201A" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#1F3D2E" } },
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#E8F5ED" } },
            "background": { "solid": { "color": "#10201A" } },
            "alignment": "left",
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#C7DCD0" } },
            "fontSize": 9
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#93AFA0" } },
            "fontSize": 10,
            "gridlineShow": false,
            "titleFontColor": { "solid": { "color": "#93AFA0" } }
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#93AFA0" } },
            "fontSize": 10,
            "gridlineShow": true,
            "gridlineColor": { "solid": { "color": "#1F3D2E" } },
            "gridlineThickness": 1,
            "titleFontColor": { "solid": { "color": "#93AFA0" } }
          }
        ],
        "legend": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#C7DCD0" } },
            "fontSize": 10
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0A1410" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#070F0C" } }
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#10201A" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#22C55E" } },
            "radius": 8
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#4ADE80" } },
            "fontSize": 30,
            "fontFamily": "Segoe UI Bold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#93AFA0" } },
            "fontSize": 11
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#10201A" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#1F3D2E" } },
            "radius": 8
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#E8F5ED" } },
            "background": { "solid": { "color": "#10201A" } },
            "fontSize": 11
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#93AFA0" } },
            "background": { "solid": { "color": "#10201A" } },
            "fontSize": 11
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "lineStyles": [
          {
            "strokeWidth": 3
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    }
  }
}
